DB_HOST=localhost
DB_PORT=5432
DB_NAME=ups_poc
DB_USER=ups_user
DB_PASSWORD=ups_pass
# optional: target non-public schema (for example DBA infra)
# DB_SCHEMA=your_schema_name
# optional: run each session as this role (requires SET ROLE privilege)
# DB_SESSION_ROLE=your_role_name

# baseline or stretch
DATA_SCALE=baseline

# optional overrides
# PROFILE_COUNT=100000
# EVENT_COUNT=5000000

# query execution profile
# Use `both` for the standard handoff artifact set (iteration latency + load/QPS).
QUERY_RUN_PROFILE=both

# iteration-mode controls (used when QUERY_RUN_PROFILE is iterations or both)
# Default 10: validates explain plans/indexes quickly. Increase to 1000+ for stable p99 benchmarks.
# QUERY_ITERATIONS=10

# load-mode controls (used when QUERY_RUN_PROFILE is load or both)
# Leave commented to use code defaults. The current defaults are shown here explicitly.
# For benchmark matrices, override only the worker count per run (for example 3, 10, 50)
# and keep the remaining load controls unchanged unless the run plan says otherwise.
# LOAD_WORKERS=3
# LOAD_DURATION_SECONDS=120
# LOAD_WARMUP_SECONDS=15
# LOAD_SEED_CONTEXTS=1000

# benchmark-matrix load overrides used in the documented 16.8 comparison runs
# QUERY_RUN_PROFILE=both        # local matrix
# QUERY_RUN_PROFILE=load        # AWS replay matrix
# LOAD_WORKERS=3                # also used with 10 and 50 in separate runs
# LOAD_DURATION_SECONDS=90
# LOAD_WARMUP_SECONDS=10

# load-mode workload shape
# LOAD_QUERY_MIX=balanced
# Required only when LOAD_QUERY_MIX=custom.
# Example custom mix used by the documented benchmark matrix:
# LOAD_QUERY_WEIGHTS_JSON='{"core_profile_lookup":2.0,"core_consent_lookup":2.0,"core_segment_candidates":1.5,"write_patch_properties":1.5,"write_upsert_consent":1.5,"complex_jsonb_segmentation":0.4,"complex_event_rollup":0.1,"complex_join_filter":0.1}'

# load-mode pg_stat_statements capture controls
# LOAD_CAPTURE_PG_STAT_STATEMENTS=true
# LOAD_PGSTAT_TOPN=100
# LOAD_PGSTAT_POLICY=soft_fail

# optional SQL query catalog overrides (paths resolved from project root)
# SQL_CORE_FILE=sql/004_queries_core.sql
# SQL_COMPLEX_FILE=sql/005_queries_complex.sql

# bloat workload controls
# BLOAT_ROUNDS=20

# local docker postgres tuning (optional; used by docker-compose.yml)
# PG_MAX_CONNECTIONS=100
# PG_SHARED_BUFFERS=512MB
# PG_WORK_MEM=16MB
# PG_MAX_PARALLEL_WORKERS_PER_GATHER=0
# PG_SHM_SIZE=1g
# PG_JIT=off

# optional explicit run id, defaults to timestamp
# RUN_ID=20260218_120000
